# Prefer ./scripts/init-web-env.sh to generate .env.web automatically.
# Copy this example manually only when you need custom bootstrap configuration.
# Single quotes prevent Compose interpolation when the password contains "$".
POSTGRES_PASSWORD='change-this-database-password'
# Used only to authorize creation of the first Owner account. Replace it before startup.
WOLT_BOOTSTRAP_TOKEN='change-this-long-random-bootstrap-token'
# 32 random bytes encoded as 64 hexadecimal characters; never store this in the database.
WOLT_MASTER_KEY='change-this-64-character-hex-encryption-key'
WOLT_WEB_PORT=8080
WOLT_ENVIRONMENT=production
WOLT_AUTO_MIGRATE=true
# Keep false for direct HTTP development. Set true when WOLT is served over HTTPS.
WOLT_SESSION_SECURE=false
WOLT_SESSION_HOURS=12

# Optional PEM bundle for a private/internal SMTP certificate authority.
# Copy the CA certificate to ./certs/smtp-ca.pem before enabling this path.
# Do not use the SMTP server's leaf certificate as the long-term trust anchor.
# WOLT_SMTP_CA_FILE=/etc/wolt/certs/smtp-ca.pem

# Docker publishes this deployment envelope when the container starts.
# Use ports from 1024 through 65535, with a maximum width of 100 ports.
WOLT_UDP_PUBLISHED_START=40000
WOLT_UDP_PUBLISHED_END=40099

# Pin production deployments to an immutable release tag.
WOLT_IMAGE='alirezasayyari/wolt:v1.1.0'
WOLT_VERSION='v1.1.0'

# Optional Phase 7 Host Agent values are generated by scripts/install-host-agent.sh.
# Never invent or commit a real token. Use compose.host-agent.yml only after installation.
# WOLT_HOST_AGENT_TOKEN=<generated-256-bit-secret>
# WOLT_HOST_AGENT_GID=<generated-host-group-id>
