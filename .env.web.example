# Prefer ./scripts/init-web-env.sh to generate .env.web automatically.
# Copy this example manually only when you need custom bootstrap configuration.
# Single quotes prevent Compose interpolation when the password contains "$".
POSTGRES_PASSWORD='change-this-database-password'
# Used only to authorize creation of the first Owner account. Replace it before startup.
WOLT_BOOTSTRAP_TOKEN='change-this-long-random-bootstrap-token'
# 32 random bytes encoded as 64 hexadecimal characters; never store this in the database.
WOLT_MASTER_KEY='change-this-64-character-hex-encryption-key'
WOLT_WEB_PORT=8080
WOLT_ENVIRONMENT=production
WOLT_AUTO_MIGRATE=true
# Keep false for direct HTTP development. Set true when WOLT is served over HTTPS.
WOLT_SESSION_SECURE=false
WOLT_SESSION_HOURS=12

# The published UDP range is fixed at container creation time in compose.web.yml.
# Application-level allocation defaults to 40000-40099 in the initial migration.
